# ──────────────────────────────────────────────────────────────────────────
# Beaumont — environment variables
#
# EVERYTHING IS OPTIONAL. The app runs end-to-end with an EMPTY .env:
#   • Maps, polygon draw, area calc  → free (Leaflet + OpenStreetMap + Turf)
#   • Address autocomplete           → free (Photon → Nominatim via /api/geocode)
#   • Emails                         → printed to the server console
#   • Card payments                  → shown disabled; transfer/cash work
#
# Copy to `.env.local` and fill in only what you want to switch on.
# ──────────────────────────────────────────────────────────────────────────

# Public site URL (used for emails, OAuth redirects, QR links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (the ONLY keys needed for the core app: accounts + data) ────────
# Create a project at https://supabase.com, run supabase/migrations/0001_init.sql,
# then paste the Project URL + anon key here. Leave blank to run in preview mode.
#
# IMPORTANT for the bilingual setup (both domains served by one deployment):
# In Supabase → Authentication → URL Configuration, add BOTH brand callbacks to
# "Redirect URLs" so Google/email return to whichever domain the user started on
# (otherwise Supabase falls back to the single Site URL and a French login lands
# on the English domain):
#     https://beaumontgroup.net/auth/callback
#     https://groupebeaumont.net/auth/callback
# (add http://localhost:3000/auth/callback too for local OAuth testing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Newer Supabase projects may call the public client key a publishable key.
# Use either this or NEXT_PUBLIC_SUPABASE_ANON_KEY; you do not need both.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Email (required for live formal quote requests) ──────────────────────────
# Local development logs emails to the console. Production quote delivery
# requires one of these providers:
#   EMAIL_PROVIDER = mailersend | brevo | resend | smtp
# All except smtp are no-credit-card free tiers.
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM="Beaumont Quotes <notifications@send.beaumontgroup.net>"
QUOTE_NOTIFICATION_TO=beaumontgroup.net@gmail.com
# Only for EMAIL_PROVIDER=smtp (also run: npm i nodemailer):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Stripe card payments (optional; also run: npm i stripe) ──────────────────
# Without these, the card option shows as "coming soon"; transfer/cash work.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Premium geocoder (optional) ──────────────────────────────────────────────
# Leave blank to use the free Photon/Nominatim endpoints.
GEOCODER=
GEOCODER_KEY=

# ── Local narration generation (never required by the deployed site) ─────────
# Used only when running `node generate-audio.js`. Never commit a real API key.
ELEVENLABS_API_KEY=
# Optional overrides; the generator has curated Canadian defaults.
ELEVENLABS_ENGLISH_VOICE_ID=
ELEVENLABS_FRENCH_VOICE_ID=
